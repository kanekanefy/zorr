diff --git a/Client/Assets/Mob.cc b/Client/Assets/Mob.cc
index a8c2a31..1786fd5 100644
--- a/Client/Assets/Mob.cc
+++ b/Client/Assets/Mob.cc
@@ -677,6 +677,32 @@ void draw_static_mob(MobID::T mob_id, Renderer &ctx, MobRenderAttributes attr) {
             draw_static_flower(ctx, attr.flower_attrs);
             break;
         };
+        case MobID::kStarfish: {
+            SET_BASE_COLOR(0xffe86e82)
+            float breath = 1.0f + 0.05f * animation_value;
+            float r_outer = radius * breath;
+            float r_inner = radius * 0.45f * breath;
+            ctx.set_fill(base_color);
+            ctx.set_stroke(Renderer::HSV(base_color, 0.8));
+            ctx.set_line_width(5);
+            ctx.round_line_cap();
+            ctx.round_line_join();
+            ctx.begin_path();
+            for (uint32_t i = 0; i < 10; ++i) {
+                float angle = M_PI * 2 * i / 10 - M_PI / 2;
+                float r = (i % 2 == 0) ? r_outer : r_inner;
+                if (i == 0) ctx.move_to(r * cosf(angle), r * sinf(angle));
+                else ctx.line_to(r * cosf(angle), r * sinf(angle));
+            }
+            ctx.line_to(r_outer * cosf(-M_PI / 2), r_outer * sinf(-M_PI / 2));
+            ctx.fill();
+            ctx.stroke();
+            ctx.set_fill(Renderer::HSV(base_color, 1.3));
+            ctx.begin_path();
+            ctx.arc(0, 0, radius * 0.25f);
+            ctx.fill();
+            break;
+        }
         default:
             assert(!"Didn't cover mob render");
             break;
