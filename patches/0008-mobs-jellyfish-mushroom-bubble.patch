diff --git a/Client/Assets/Mob.cc b/Client/Assets/Mob.cc
index 1786fd5..c9bc7da 100644
--- a/Client/Assets/Mob.cc
+++ b/Client/Assets/Mob.cc
@@ -703,6 +703,107 @@ void draw_static_mob(MobID::T mob_id, Renderer &ctx, MobRenderAttributes attr) {
             ctx.fill();
             break;
         }
+        case MobID::kJellyfish: {
+            // Cyan bell + 4 wavy tentacles. animation_value drives a slow
+            // pulse — bell breathes 1.0 → 1.08, tentacles wag opposite phase.
+            SET_BASE_COLOR(0xff5fd4f0)
+            float breath = 1.0f + 0.08f * animation_value;
+            float r_bell = radius * 0.85f * breath;
+            ctx.set_stroke(Renderer::HSV(base_color, 0.7));
+            ctx.set_line_width(4);
+            ctx.round_line_cap();
+            ctx.round_line_join();
+            // tentacles first (behind bell)
+            float wag = 0.4f * sinf(animation_value * M_PI);
+            for (uint32_t i = 0; i < 4; ++i) {
+                float tx0 = (i - 1.5f) * radius * 0.35f;
+                ctx.begin_path();
+                ctx.move_to(tx0, r_bell * 0.4f);
+                ctx.bcurve_to(
+                    tx0 + wag * radius * 0.3f, r_bell * 0.8f,
+                    tx0 - wag * radius * 0.3f, r_bell * 1.2f,
+                    tx0 + wag * radius * 0.2f, radius * 1.4f
+                );
+                ctx.stroke();
+            }
+            // bell dome — partial_arc with 6th arg (anticlockwise) = 0
+            ctx.set_fill(base_color);
+            ctx.begin_path();
+            ctx.partial_arc(0, 0, r_bell, M_PI, M_PI * 2, 0);
+            ctx.line_to(r_bell, r_bell * 0.2f);
+            ctx.line_to(-r_bell, r_bell * 0.2f);
+            ctx.close_path();
+            ctx.fill();
+            ctx.stroke();
+            // inner highlight
+            ctx.set_fill(Renderer::HSV(base_color, 1.4));
+            ctx.begin_path();
+            ctx.arc(0, -r_bell * 0.3f, r_bell * 0.25f);
+            ctx.fill();
+            break;
+        }
+        case MobID::kMushroom: {
+            // Classic Mario red-cap. Cap dome on top, off-white stem below,
+            // 3 white dots on the cap. No animation — mushrooms don't move.
+            SET_BASE_COLOR(0xffc94e44)
+            // stem
+            ctx.set_fill(0xfff0e6cc);
+            ctx.set_stroke(Renderer::HSV(0xfff0e6cc, 0.7));
+            ctx.set_line_width(4);
+            ctx.round_line_join();
+            ctx.begin_path();
+            ctx.move_to(-radius * 0.45f, 0);
+            ctx.line_to(radius * 0.45f, 0);
+            ctx.line_to(radius * 0.55f, radius * 0.75f);
+            ctx.line_to(-radius * 0.55f, radius * 0.75f);
+            ctx.close_path();
+            ctx.fill();
+            ctx.stroke();
+            // cap (half-disc)
+            ctx.set_fill(base_color);
+            ctx.set_stroke(Renderer::HSV(base_color, 0.7));
+            ctx.begin_path();
+            ctx.partial_arc(0, 0, radius, M_PI, M_PI * 2, 0);
+            ctx.close_path();
+            ctx.fill();
+            ctx.stroke();
+            // 3 white spots
+            ctx.set_fill(0xffffffff);
+            for (uint32_t i = 0; i < 3; ++i) {
+                float a = M_PI + (i + 1) * M_PI / 4;
+                float r = radius * 0.55f;
+                float dot_r = radius * (i == 1 ? 0.18f : 0.13f);
+                ctx.begin_path();
+                ctx.arc(r * cosf(a), r * sinf(a), dot_r);
+                ctx.fill();
+            }
+            break;
+        }
+        case MobID::kBubbleMob: {
+            // Translucent blue bubble + crescent highlight on top-left.
+            // breath makes it pulse — feels alive but harmless.
+            SET_BASE_COLOR(0xff7fbfff)
+            float breath = 1.0f + 0.06f * animation_value;
+            float r = radius * breath;
+            ctx.set_fill(base_color);
+            ctx.set_stroke(Renderer::HSV(base_color, 0.6));
+            ctx.set_line_width(4);
+            ctx.begin_path();
+            ctx.arc(0, 0, r);
+            ctx.fill();
+            ctx.stroke();
+            // inner translucent ring
+            ctx.set_fill(0x55ffffff);
+            ctx.begin_path();
+            ctx.arc(0, 0, r * 0.72f);
+            ctx.fill();
+            // top-left crescent highlight
+            ctx.set_fill(0xffffffff);
+            ctx.begin_path();
+            ctx.arc(-r * 0.35f, -r * 0.35f, r * 0.18f);
+            ctx.fill();
+            break;
+        }
         default:
             assert(!"Didn't cover mob render");
             break;
