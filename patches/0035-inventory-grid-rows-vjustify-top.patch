+    // 0033 because every attempt reworked cell visuals, scroll math, or
+    // header — never row construction. Pattern matches PetalGallery.cc:72
+    // which also sets v_justify=Top on rows added via add_child.
     Element *grid = new Ui::VContainer({}, 0, 6, { .h_justify = Style::Left });
     for (size_t i = 0; i < ids.size(); i += COLS) {
