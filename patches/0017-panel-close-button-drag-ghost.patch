+// Patch 0017: shared close button — used by both Inventory and Craft panels.
+// They each include `make_panel_close_button()` in the header HFlexContainer
+// so the panel can be dismissed without clicking the sidebar icon again.
+void Ui::on_panel_close(Element *, uint8_t event) {
+    if (event != Ui::kClick) return;
+    Ui::panel_open = Panel::kNone;
+}
+
+Element *Ui::make_panel_close_button() {
+    return new Ui::Button(24, 24,
+        new Ui::StaticText(14, "x", { .fill = 0xffffffff }),
+        Ui::on_panel_close, nullptr,
+        { .fill = 0xff8a3a3a, .stroke_hsv = 0.6, .line_width = 2, .round_radius = 3 });
+}
+
+// Patch 0017: drag-from-inventory ghost. While `Game::inventory_drag_id` is
+// set (between mousedown on an inventory cell and release somewhere), render
+// a small petal sprite that follows the cursor. Discoverability — without
+// it the drag is invisible and users wouldn't know it was happening.
+namespace {
+class InventoryDragGhost final : public Ui::Element {
+public:
+    InventoryDragGhost() : Element(36, 36, {
+        .should_render = []() { return Game::inventory_drag_id != PetalID::kNone; },
+        .layer = 2  // above panel contents, above loadout
+    }) {
+        // Per-frame: snap to mouse position (in window-centered coords).
+        style.animate = [](Ui::Element *e, Ui::Renderer &) {
+            e->x = (Input::mouse_x - Ui::window_width / 2) / Ui::scale;
+            e->y = (Input::mouse_y - Ui::window_height / 2) / Ui::scale;
+        };
+    }
+    virtual void on_render(Ui::Renderer &ctx) override {
+        PetalID::T id = Game::inventory_drag_id;
+        if (id == PetalID::kNone || id >= PetalID::kNumPetals) return;
+        ctx.set_global_alpha(0.85f);
+        ctx.scale(width / 60);
+        draw_loadout_background(ctx, id);
+    }
+};
+}
+
+Element *Ui::make_inventory_drag_ghost() {
+    return new InventoryDragGhost();
+}
