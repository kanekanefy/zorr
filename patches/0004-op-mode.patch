diff --git a/Shared/OpMode.hh b/Shared/OpMode.hh
new file mode 100644
index 0000000..f794a2a
--- /dev/null
+++ b/Shared/OpMode.hh
@@ -0,0 +1,26 @@
+#pragma once
+
+// zorr OP-Mode tunables — Phase 1: compile-time constants.
+// "Super Fun Mode" preset — designed for ~30-minute full-content runs.
+// Phase 2 will replace these with values loaded from /etc/zorr/op-config.json.
+
+namespace OpMode {
+    // Leveling — Phase 5A: 从"秒升级"调整成"快进游戏" (60-90min 通关感)
+    inline constexpr float LEVEL_DIV = 30.0f;        // XP-to-next-level divided by this (was 100 → 30)
+    inline constexpr float XP_MULT = 8.0f;           // XP per kill * this (was 50 → 8, more meaningful progression)
+    inline constexpr bool  ALL_SLOTS_FROM_START = true;
+
+    // Survivability — Phase 5A: 给战斗增加紧张感
+    inline constexpr float HP_MULT = 5.0f;           // Flower HP * this (was 10 → 5)
+    inline constexpr float PETAL_DMG_MULT = 20.0f;   // Petal-to-mob damage * this (unchanged — killing mobs should still feel powerful)
+    inline constexpr float MOB_DMG_MULT = 0.6f;      // Mob-to-flower damage * this (was 0.1 → 0.6, mobs now actually hurt)
+
+    // Economy (掉率高 + 怪密度合理 — 平衡爽快与客户端 FPS)
+    inline constexpr float DROP_MULT = 8.0f;         // Drop chance * this (capped at 1.0 by frand). Was 20 → 8 to reduce drop pile-up & client lag.
+    inline constexpr float DENSITY_MULT = 3.0f;      // Mob density * this. Was 5 → 3 to reduce entity count.
+
+    // Bot drops — Phase 5B2: 死亡时除了原生 drops,额外按 tier 加 N 个随机 petal
+    inline constexpr int   BOT_BONUS_DROPS_ROOKIE     = 1;
+    inline constexpr int   BOT_BONUS_DROPS_COMPETITOR = 2;
+    inline constexpr int   BOT_BONUS_DROPS_VETERAN    = 3;
+}
