+
+// --- Patch 0010: slot-based craft API ------------------------------------
+//
+// The craft panel UI lets the player click 5 specific petals into 5 slots,
+// then hit Craft. This is more strategic than the original "random 5 of
+// rarity X" because the player chooses which low-value petals to burn.
+//
+// Rules:
+//   - All 5 slots must be the same rarity (the active tab).
+//   - Switching the active rarity tab clears slots (so you don't accidentally
+//     mix tiers).
+//   - A petal can occupy multiple slots if you own enough copies — e.g. 5
+//     Roses → 5 Rose slots. craft_slots_add_petal verifies inventory minus
+//     slots-already-using-this-petal is ≥ 1.
+//   - Craft consumes the exact 5 slotted petals, then uses the same
+//     success/destroy rules as try_craft(rarity).
+
+void Game::craft_slots_reset() {
+    for (uint8_t i = 0; i < 5; ++i) Game::craft_slots[i] = PetalID::kNone;
+    Game::craft_slot_count = 0;
+}
+
+void Game::craft_slots_set_rarity(uint8_t rarity) {
+    if (rarity >= RarityID::kNumRarities) return;
+    if (rarity != Game::craft_active_rarity) Game::craft_slots_reset();
+    Game::craft_active_rarity = rarity;
+}
+
+bool Game::craft_slots_add_petal(PetalID::T id) {
+    if (id == PetalID::kNone || id >= PetalID::kNumPetals) return false;
+    if (PETAL_DATA[id].rarity != Game::craft_active_rarity) return false;
+    if (Game::craft_slot_count >= 5) return false;
+    // How many of this petal are already in slots?
+    uint32_t slotted = 0;
+    for (uint8_t i = 0; i < Game::craft_slot_count; ++i)
+        if (Game::craft_slots[i] == id) slotted++;
+    if (Game::persistent_inventory[id] <= slotted) return false;  // not enough left
+    Game::craft_slots[Game::craft_slot_count++] = id;
+    return true;
+}
+
+PetalID::T Game::try_craft_from_slots() {
+    if (Game::craft_slot_count != 5) {
+        Game::last_craft_result    = PetalID::kNone;
+        Game::last_craft_success   = 0;
+        Game::last_craft_destroyed = 0;
+        Game::last_craft_timestamp = Game::timestamp;
+        return PetalID::kNone;
+    }
+    uint8_t rarity = Game::craft_active_rarity;
+    if (rarity >= RarityID::kNumRarities - 1) {
+        // Top tier — no upgrade target.
+        Game::craft_slots_reset();
+        Game::last_craft_result    = PetalID::kNone;
+        Game::last_craft_success   = 0;
+        Game::last_craft_destroyed = 0;
+        Game::last_craft_timestamp = Game::timestamp;
+        return PetalID::kNone;
+    }
+
+    // Snapshot the consumed list before mutating inventory.
+    PetalID::T consumed[5];
+    for (uint8_t i = 0; i < 5; ++i) consumed[i] = Game::craft_slots[i];
+    // Consume from inventory.
+    for (uint8_t i = 0; i < 5; ++i) {
+        if (Game::persistent_inventory[consumed[i]] > 0)
+            Game::persistent_inventory[consumed[i]]--;
+    }
+    Game::craft_slots_reset();
+
+    // Same success table as the random-5 path — picks intentionally don't
+    // change odds; they just give the player agency over which copies burn.
+    constexpr float SUCCESS_RATES[RarityID::kNumRarities] =
+        {0.60f, 0.45f, 0.30f, 0.20f, 0.12f, 0.06f, 0.03f};
+    if (frand() < SUCCESS_RATES[rarity]) {
+        std::vector<PetalID::T> next_pool;
+        for (PetalID::T id = PetalID::kBasic; id < PetalID::kNumPetals; ++id)
+            if (PETAL_DATA[id].rarity == rarity + 1) next_pool.push_back(id);
+        if (next_pool.empty()) {
+            // No higher-rarity defined — refund.
+            for (uint8_t i = 0; i < 5; ++i) Game::persistent_inventory[consumed[i]]++;
+            Game::last_craft_result    = PetalID::kNone;
+            Game::last_craft_success   = 0;
+            Game::last_craft_destroyed = 0;
+            Game::last_craft_timestamp = Game::timestamp;
+            return PetalID::kNone;
+        }
+        PetalID::T result = next_pool[(uint32_t)(frand() * next_pool.size())];
+        Game::persistent_inventory[result]++;
+        Game::seen_petals[result] = 1;
+        Game::last_craft_result    = result;
+        Game::last_craft_success   = 1;
+        Game::last_craft_destroyed = 0;
+        Game::last_craft_timestamp = Game::timestamp;
+        return result;
+    }
+    // Fail: destroy 1..4, refund 5-N.
+    uint8_t destroyed = 1 + (uint8_t)(frand() * 4);
+    if (destroyed > 4) destroyed = 4;
+    for (uint8_t i = destroyed; i < 5; ++i) {
+        Game::persistent_inventory[consumed[i]]++;
+    }
+    Game::last_craft_result    = PetalID::kNone;
+    Game::last_craft_success   = 0;
+    Game::last_craft_destroyed = destroyed;
+    Game::last_craft_timestamp = Game::timestamp;
+    return PetalID::kNone;
 }
