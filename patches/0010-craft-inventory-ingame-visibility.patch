diff --git a/Client/Ui/TitleScreen/MetaSidebar.cc b/Client/Ui/TitleScreen/MetaSidebar.cc
new file mode 100644
index 0000000..7f7e49a
--- /dev/null
+++ b/Client/Ui/TitleScreen/MetaSidebar.cc
@@ -0,0 +1,125 @@
+// Patch 0010: persistent left-side icon sidebar for meta-game panels.
+//
+// Why a separate file: Inventory/Craft panels are "meta" — they're player
+// state that persists across game sessions, not tied to a single match. So
+// the entry points need to be visible everywhere (title + in game). gardn's
+// existing panel buttons (Settings/Petals/Mobs/Changelog) live in
+// `make_panel_buttons` inside title_ui_window and disappear when the player
+// enters the game. We can't reuse that pattern — we need other_ui_window
+// (the always-rendered layer) and our own little container.
+//
+// Visual: vertical strip on the LEFT edge, mid-height. Hornex's sandbox UI
+// puts similar icons in the same position (see docs/hornex-reference/
+// assets/screens/01-menu-main.png).
+//
+// Each button toggles `Ui::panel_open`. The panels themselves
+// (Inventory.cc / Craft.cc) read panel_open in their should_render.
+
+#include <Client/Ui/TitleScreen/TitleScreen.hh>
+
+#include <Client/Ui/Button.hh>
+#include <Client/Ui/Container.hh>
+// StaticIcon is pulled in transitively via Ui.hh — adding it explicitly
+// triggers a redefinition error because StaticIcon.hh lacks include guards
+// (caught the hard way on the first build).
+#include <Client/Ui/StaticText.hh>
+#include <Client/Ui/Extern.hh>
+
+#include <Client/Assets/Assets.hh>
+#include <Client/Game.hh>
+
+#include <cmath>
+
+using namespace Ui;
+
+namespace {
+
+// Bag icon — for Inventory. Simple rounded rectangle + handle.
+void draw_bag_icon(Element *elt, Renderer &ctx) {
+    ctx.scale(elt->width / 32);
+    ctx.set_fill(0xffffffff);
+    ctx.set_stroke(0xff222222);
+    ctx.set_line_width(2);
+    // handle (semicircle)
+    ctx.begin_path();
+    ctx.partial_arc(0, -6, 6, M_PI, 0, 0);
+    ctx.stroke();
+    // body
+    ctx.begin_path();
+    ctx.round_rect(-9, -4, 18, 14, 3);
+    ctx.fill();
+    ctx.stroke();
+}
+
+// Anvil icon — for Craft. Trapezoidal anvil silhouette.
+void draw_anvil_icon(Element *elt, Renderer &ctx) {
+    ctx.scale(elt->width / 32);
+    ctx.set_fill(0xffffffff);
+    ctx.set_stroke(0xff222222);
+    ctx.set_line_width(2);
+    ctx.round_line_join();
+    // anvil shape: wide top, narrow waist, base
+    ctx.begin_path();
+    ctx.move_to(-10, -6);
+    ctx.line_to(10, -6);
+    ctx.line_to(10, -2);
+    ctx.line_to(4, -2);
+    ctx.line_to(4, 4);
+    ctx.line_to(8, 4);
+    ctx.line_to(8, 8);
+    ctx.line_to(-8, 8);
+    ctx.line_to(-8, 4);
+    ctx.line_to(-4, 4);
+    ctx.line_to(-4, -2);
+    ctx.line_to(-10, -2);
+    ctx.close_path();
+    ctx.fill();
+    ctx.stroke();
+}
+
+void on_inventory_click(Element *, uint8_t event) {
+    if (event != Ui::kClick) return;
+    Ui::panel_open = (Ui::panel_open == Panel::kInventory) ? Panel::kNone : Panel::kInventory;
+}
+void on_craft_click(Element *, uint8_t event) {
+    if (event != Ui::kClick) return;
+    Ui::panel_open = (Ui::panel_open == Panel::kCraft) ? Panel::kNone : Panel::kCraft;
+}
+
+bool inv_active() { return Ui::panel_open == Panel::kInventory; }
+bool craft_active() { return Ui::panel_open == Panel::kCraft; }
+
+} // namespace
+
+Element *Ui::make_meta_sidebar() {
+    constexpr float W = 44.0f;
+
+    Ui::Button *inv_btn = new Ui::Button(W, W,
+        new Ui::StaticIcon(draw_bag_icon, 32, 32),
+        on_inventory_click,
+        inv_active,
+        { .fill = 0xff7c5cb0, .stroke_hsv = 0.7, .line_width = 3, .round_radius = 5 });
+
+    Ui::Button *craft_btn = new Ui::Button(W, W,
+        new Ui::StaticIcon(draw_anvil_icon, 32, 32),
+        on_craft_click,
+        craft_active,
+        { .fill = 0xff3a8a3a, .stroke_hsv = 0.7, .line_width = 3, .round_radius = 5 });
+
+    Element *sidebar = new Ui::VContainer({
+        inv_btn,
+        craft_btn
+    }, 8, 8, {
+        .fill = 0x66000000,
+        .stroke_hsv = 0.0,
+        .line_width = 0,
+        .round_radius = 6,
+        // Always rendered — that's the whole point.
+        .should_render = []() { return true; },
+        .h_justify = Style::Left,
+        .v_justify = Style::Middle
+    });
+    // Pin to the left edge
+    sidebar->x = 12;
+    return sidebar;
+}
