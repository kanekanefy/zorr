+class InventoryPetalCell final : public Element {
+public:
+    PetalID::T id;
+    InventoryPetalCell(PetalID::T pid)
+        : Element(60, 80, {
+            .fill = RARITY_COLORS[PETAL_DATA[pid].rarity],
+            .stroke_hsv = 0.85f,
+            .line_width = 2,
+            .round_radius = 5,
+            .v_justify = Style::Top,
+        }), id(pid) {}
+
+    void on_render(Renderer &ctx) override {
+        uint32_t n = Game::persistent_inventory[id];
+        bool owned = n > 0;
+
+        // Swap visual style for owned vs unowned vs active-drag.
+        uint32_t saved_fill   = style.fill;
+        float    saved_hsv    = style.stroke_hsv;
+        float    saved_lw     = style.line_width;
+        if (!owned) {
+            style.fill        = 0xff2e2e2e;
+            style.stroke_hsv  = 0.5f;
+            style.line_width  = 1;
+        } else if (Game::inventory_drag_id == id) {
+            style.stroke_hsv  = 1.4f;
+            style.line_width  = 4;
+        }
+        Element::on_render(ctx);
+        style.fill       = saved_fill;
+        style.stroke_hsv = saved_hsv;
+        style.line_width = saved_lw;
+
+        // --- 1) Petal sprite, top half of the cell ---------------------
+        // draw_loadout_background renders at "60px reference size" centered
+        // at origin. We translate up by 12 (so it sits in the upper half),
+        // then scale to ~62% so the sprite leaves room for the name label
+        // underneath.
+        if (!owned) ctx.set_global_alpha(0.22f);
+        ctx.translate(0, -12);
+        ctx.scale(0.62f);
+        draw_loadout_background(ctx, id);
+        ctx.scale(1.0f / 0.62f);
+        ctx.translate(0, 12);
+        if (!owned) ctx.set_global_alpha(1.0f);
+
+        // --- 2) Petal name, bottom of cell -----------------------------
+        // 9pt with stroke_scale 0.22 — heavier outline than the badge so
+        // the name reads cleanly against the rarity background.
+        if (owned) {
+            float ny = height / 2 - 8;
+            ctx.translate(0, ny);
+            ctx.draw_text(PETAL_DATA[id].name, {
+                .fill         = 0xffffffff,
+                .size         = 9,
+                .stroke_scale = 0.22,
+            });
+            ctx.translate(0, -ny);
+        }
+
+        // --- 3) Count badge, top-right (DRAWN LAST so it's on top) -----
+        // Format: "x44", "x5k", "x500m". Tucked into the corner about 14px
+        // from the right edge and 10px from the top.
+        if (owned) {
+            std::string badge = std::string("x") + format_score((float)n);
+            float bx = width / 2 - 14;
+            float by = -height / 2 + 10;
+            ctx.translate(bx, by);
+            ctx.draw_text(badge.c_str(), {
+                .fill         = 0xffffffff,
+                .size         = 12,
+                .stroke_scale = 0.25,
+            });
+            ctx.translate(-bx, -by);
+        }
+    }
+
+    void on_event(uint8_t event) override {
+        bool has = Game::persistent_inventory[id] > 0;
+        if (!has) {
+            // Unowned cells are inert — no equip, no drag, no tooltip.
+            rendering_tooltip = 0;
+            return;
         }
-        virtual void on_event(uint8_t event) override {
-            if (event == kMouseDown) {
