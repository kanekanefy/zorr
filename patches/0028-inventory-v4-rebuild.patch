-            if (event != kFocusLost && Game::persistent_inventory[id] > 0) {
-                rendering_tooltip = 1;
-                tooltip = Ui::UiLoadout::petal_tooltips[id];
-            } else {
-                rendering_tooltip = 0;
-            }
+        if (event == kMouseDown && Game::alive()) {
+            Game::inventory_drag_id = id;
         }
-    };
+        if (event == kClick && Game::alive()) {
+            Game::equip_to_first_empty(id);
+            Game::inventory_drag_id = PetalID::kNone;
+        }
+        if (event != kFocusLost) {
+            rendering_tooltip = 1;
+            tooltip = Ui::UiLoadout::petal_tooltips[id];
+        } else {
+            rendering_tooltip = 0;
+        }
+    }
+};
+
+// Wipe button callback. Free function — gardn's Ui::Button accepts a
+// function pointer (not std::function), so capturing lambdas don't work.
+// Zeros every persistent_inventory slot in one shot. No confirmation
+// dialog yet — keep it simple, can add a "hold to confirm" later.
+void wipe_inventory_cb(Element *, uint8_t event) {
+    if (event != Ui::kClick) return;
+    for (PetalID::T id = PetalID::kBasic; id < PetalID::kNumPetals; ++id) {
+        Game::persistent_inventory[id] = 0;
+    }
 }
 
