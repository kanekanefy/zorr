--- a/Client/Ui/ScrollContainer.cc
+++ b/Client/Ui/ScrollContainer.cc
@@ -29,7 +29,26 @@ void ScrollContainer::on_render(Renderer &ctx) {
     DEBUG_ONLY(assert(children.size() == 2));
     Element *scroll = children[1];
     Element *content = children[0];
+    // Patch 0027: hide scrollbar when no scrolling is needed.
+    //
+    // Old behavior:
+    //   - ScrollBar was always rendered as an HContainer child.
+    //   - When content fit inside viewport, the bar was visible at its
+    //     default 100px height and reserved horizontal space but did
+    //     nothing — wheel events were not processed.
+    //   - User report: "I see a scrollbar but mouse wheel doesn't move
+    //     it" — symptom of this exact condition (panel max_height bumped
+    //     to 650 in patch 0024, while collection grid is only ~580px).
+    //
+    // New behavior:
+    //   - When content fits, fully hide the bar (fill = 0) so the user
+    //     doesn't think it's interactive.
+    //   - Reset lerp_scroll to 0 so re-opening a previously-scrolled
+    //     panel starts at the top.
+    //   - When scrolling IS needed, restore the bar fill and run the
+    //     wheel/drag/touch math as before.
     if (height < content->height) {
+        scroll->style.fill = 0x40000000;
         scroll->height = height * height / content->height;
         float ratio = height == scroll->height ? 1 : (content->height - height) / (height - scroll->height);
         if (std::abs(Input::mouse_x - screen_x) < width * Ui::scale / 2
@@ -46,8 +65,11 @@ void ScrollContainer::on_render(Renderer &ctx) {
         lerp_scroll = fclamp(lerp_scroll, 0, height - scroll->height);
         scroll->y = lerp(scroll->y, lerp_scroll, Ui::lerp_amount);
         content->y = lerp(content->y, -ratio * lerp_scroll, Ui::lerp_amount);
-    } else 
+    } else {
+        scroll->style.fill = 0;
         content->y = scroll->y = 0;
+        lerp_scroll = 0;
+    }
     RenderContext c(&ctx);
     ctx.clip_rect(0,0,width,height);
     for (Element *elt : children) {
