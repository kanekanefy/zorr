+// Patch 0021: click-to-equip. Patch 0022: extended to auto-replace the
+// lowest-rarity slot when all 16 slots are full.
+//
+// Resolution order:
+//   1. First empty primary slot  → put it there
+//   2. First empty secondary slot → put it there
+//   3. Lowest-rarity slot in EITHER row whose petal is strictly lower
+//      rarity than the new one → replace it (displaced petal refunds back
+//      to inventory). Guards against accidental downgrade — you can't lose
+//      a Mythic to a Common click.
+//   4. None of the above → return 0xff, no-op. Caller decides if to show
+//      a "loadout full" hint.
+//
+// All slot mutations go through equip_from_inventory which talks to the
+// server; client-local persistent_inventory bookkeeping happens here
+// (decrement new, refund old) so the UI updates instantly.
 uint8_t Game::equip_to_first_empty(PetalID::T id) {
     if (!Game::alive()) return 0xff;
     if (id == PetalID::kNone || id >= PetalID::kNumPetals) return 0xff;
     if (Game::persistent_inventory[id] == 0) return 0xff;
-    // Primary: indices 0..loadout_count-1 in static-pos space.
+
+    // Step 1: empty primary
     for (uint8_t pos = 0; pos < Game::loadout_count; ++pos) {
         if (Game::cached_loadout[pos] == PetalID::kNone) {
             Game::persistent_inventory[id]--;
@@ -119,7 +131,7 @@ uint8_t Game::equip_to_first_empty(PetalID::T id) {
             return pos;
         }
     }
-    // Secondary: indices MAX_SLOT_COUNT..MAX_SLOT_COUNT+loadout_count-1.
+    // Step 2: empty secondary
     for (uint8_t pos = MAX_SLOT_COUNT; pos < MAX_SLOT_COUNT + Game::loadout_count; ++pos) {
         if (Game::cached_loadout[pos] == PetalID::kNone) {
             Game::persistent_inventory[id]--;
@@ -127,5 +139,25 @@ uint8_t Game::equip_to_first_empty(PetalID::T id) {
             return pos;
         }
     }
-    return 0xff;
+    // Step 3: replace lowest-rarity slot that's STRICTLY lower than new
+    uint8_t new_rarity = PETAL_DATA[id].rarity;
+    uint8_t target_pos = 0xff;
+    uint8_t target_rarity = new_rarity;  // strictly-less-than this
+    auto consider = [&](uint8_t pos) {
+        PetalID::T old = Game::cached_loadout[pos];
+        if (old == PetalID::kNone || old >= PetalID::kNumPetals) return;
+        uint8_t r = PETAL_DATA[old].rarity;
+        if (r < target_rarity) { target_rarity = r; target_pos = pos; }
+    };
+    for (uint8_t pos = 0; pos < Game::loadout_count; ++pos) consider(pos);
+    for (uint8_t pos = MAX_SLOT_COUNT; pos < MAX_SLOT_COUNT + Game::loadout_count; ++pos) consider(pos);
+
+    if (target_pos != 0xff) {
+        PetalID::T old_id = Game::cached_loadout[target_pos];
+        Game::persistent_inventory[id]--;
+        Game::persistent_inventory[old_id]++;  // refund the displaced petal
+        Game::equip_from_inventory(target_pos, id);
+        return target_pos;
+    }
+    return 0xff;  // every slot >= new petal's rarity, no downgrade allowed
