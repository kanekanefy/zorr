-constexpr double RESULT_DISPLAY_SECONDS = 8.0;
+// Patch 0013: fix invisible-banner bug. Game::timestamp is in milliseconds
+// (assigned from requestAnimationFrame via Game::tick), but patch 0012's
+// RESULT_DISPLAY_SECONDS was 8.0 — so the banner only showed for 8 ms
+// (under one frame). Use ms units explicitly. Also bumped font to 20pt and
+// added an inline petal sprite next to the success text so the player can
+// instantly see WHICH petal they crafted.
+constexpr double RESULT_DISPLAY_MS = 8000.0;
+
+// Small Element that draws the last-crafted petal sprite. We pre-build it
+// once and let on_render read Game::last_craft_result live each frame.
+class LastResultPetalSprite final : public Element {
+public:
+    LastResultPetalSprite() : Element(28, 28, {}) {}
+    virtual void on_render(Renderer &ctx) override {
+        if (!Game::last_craft_success) return;
+        ctx.scale(width / 60);
+        draw_loadout_background(ctx, Game::last_craft_result);
+    }
+};
 
