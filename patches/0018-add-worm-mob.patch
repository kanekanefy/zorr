diff --git a/Client/Assets/Mob.cc b/Client/Assets/Mob.cc
index c9bc7da..24f00a8 100644
--- a/Client/Assets/Mob.cc
+++ b/Client/Assets/Mob.cc
@@ -804,6 +804,49 @@ void draw_static_mob(MobID::T mob_id, Renderer &ctx, MobRenderAttributes attr) {
             ctx.fill();
             break;
         }
+        case MobID::kWorm: {
+            // Patch 0018: chunky segmented earthy body. Same "two end caps
+            // + main bell" skeleton as Centipede (so it composes correctly
+            // when the Segmented system stitches the body together), but
+            // with a darker brown-red palette and bigger eye dots so it
+            // visually reads as "Worm, not Centipede." Antennae omitted —
+            // worms don't have them, and skipping them keeps draw cost
+            // lower for what's already a tankier mob to render in groups.
+            SET_BASE_COLOR(0xff8b5a3c)  // earthy brown-red
+            ctx.set_fill(0xff2a1810);
+            ctx.begin_path();
+            ctx.arc(0, -32, 17);  // back cap (slightly larger than centipede)
+            ctx.fill();
+            ctx.begin_path();
+            ctx.arc(0, 32, 17);   // front cap
+            ctx.fill();
+            ctx.begin_path();
+            ctx.arc(0, 0, 38);    // main body bell
+            ctx.set_fill(base_color);
+            ctx.fill();
+            ctx.set_stroke(Renderer::HSV(base_color, 0.7));
+            ctx.set_line_width(8);
+            ctx.stroke();
+            // Two eye dots on the head segment (forward = +y direction here,
+            // matching how Centipede draws the head).
+            if (!BitMath::at(flags, 1)) {
+                ctx.set_fill(0xffffffff);
+                ctx.begin_path();
+                ctx.arc(-9, 30, 5);
+                ctx.fill();
+                ctx.begin_path();
+                ctx.arc(9, 30, 5);
+                ctx.fill();
+                ctx.set_fill(0xff111111);
+                ctx.begin_path();
+                ctx.arc(-9, 30, 2.5);
+                ctx.fill();
+                ctx.begin_path();
+                ctx.arc(9, 30, 2.5);
+                ctx.fill();
+            }
+            break;
+        }
         default:
             assert(!"Didn't cover mob render");
             break;
