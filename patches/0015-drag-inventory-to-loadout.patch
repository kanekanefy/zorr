diff --git a/Client/Network.cc b/Client/Network.cc
index 16ebff7..972c445 100644
--- a/Client/Network.cc
+++ b/Client/Network.cc
@@ -86,4 +86,18 @@ void Game::swap_all_petals() {
     if (!Game::alive()) return;
     for (uint32_t i = 0; i < Game::loadout_count; ++i)
         Ui::ui_swap_petals(i, i + Game::loadout_count);
+}
+
+// Patch 0015: send "equip this inventory petal into this loadout slot."
+// The client also adjusts persistent_inventory locally (decrement new, refund
+// old) so the inventory panel reflects the change immediately, before the
+// server's loadout-sync round-trip arrives.
+void Game::equip_from_inventory(uint8_t pos, PetalID::T id) {
+    Writer writer(static_cast<uint8_t *>(OUTGOING_PACKET));
+    if (!Game::alive()) return;
+    if (id == PetalID::kNone || id >= PetalID::kNumPetals) return;
+    writer.write<uint8_t>(Serverbound::kEquipFromInventory);
+    writer.write<uint8_t>(pos);
+    writer.write<uint8_t>((uint8_t)id);
+    socket.send(writer.packet, writer.at - writer.packet);
 }
