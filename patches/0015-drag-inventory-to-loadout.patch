diff --git a/Server/Client.cc b/Server/Client.cc
index 284b10d..62541a2 100644
--- a/Server/Client.cc
+++ b/Server/Client.cc
@@ -147,6 +147,36 @@ void Client::on_message(WebSocket *ws, std::string_view message, uint64_t code)
             player.set_loadout_ids(pos2, tmp);
             break;
         }
+        // Patch 0015: equip a petal_id from the client's inventory directly
+        // into a loadout slot. Inventory state lives only on the client
+        // (persistent_inventory, persisted via Storage.cc), so there's no
+        // server-side ownership check — we trust the client. Sanity-check
+        // the slot index and petal_id range; everything else is "client
+        // policy." This is consistent with the rest of the gardn protocol
+        // which already trusts client picks (kPetalSwap, kPetalDelete).
+        case Serverbound::kEquipFromInventory: {
+            if (!client->alive()) break;
+            Simulation *simulation = &client->game->simulation;
+            Entity &camera = simulation->get_ent(client->camera);
+            Entity &player = simulation->get_ent(camera.get_player());
+            if (client->check_invalid(validator.validate_uint8() && validator.validate_uint8())) return;
+            uint8_t pos = reader.read<uint8_t>();
+            uint8_t pid_raw = reader.read<uint8_t>();
+            if (pos >= MAX_SLOT_COUNT + player.get_loadout_count()) break;
+            if (pid_raw == PetalID::kNone || pid_raw >= PetalID::kNumPetals) break;
+            PetalID::T new_id = (PetalID::T)pid_raw;
+            // Same path as Spawn.cc::player_spawn — set loadout id, then if
+            // the slot is "active" (in the primary row) make sure the slot
+            // gets re-spawned with the new petal type. set_loadout_ids
+            // handles secondaries automatically.
+            player.set_loadout_ids(pos, new_id);
+            if (pos < player.get_loadout_count()) {
+                LoadoutSlot &slot = player.loadout[pos];
+                slot.update_id(simulation, new_id);
+                slot.force_reload();
+            }
+            break;
+        }
     }
 }
 
