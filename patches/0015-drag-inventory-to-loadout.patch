@@ -50,6 +50,12 @@ namespace Game {
     uint8_t    craft_slot_count = 0;
     uint8_t    craft_active_rarity = RarityID::kCommon;
 
+    // Patch 0015: drag-from-inventory state. The Inventory panel's cells set
+    // this to their petal_id on kMouseDown; Game::tick watches for mouse
+    // release while it's set, finds the loadout slot under the cursor, and
+    // sends kEquipFromInventory. Reset to kNone when drag ends or cancels.
+    PetalID::T inventory_drag_id = PetalID::kNone;
+
     double timestamp = 0;
 
     double score = 0;
@@ -300,12 +306,60 @@ void Game::tick(double time) {
         // set when it gets large — cheap and correctness-safe (worst case
         // a single missed dedupe right after clear).
         if (counted_drops.size() > 1024) counted_drops.clear();
+
+        // Patch 0015: drag-from-inventory release detection. Inventory cells
+        // set Game::inventory_drag_id on kMouseDown; we watch for mouse
+        // release here and, if it happens over a loadout slot, send the
+        // equip message. Visually-distinct from the existing LoadoutPetal
+        // swap drag (which uses UiLoadoutPetal::selected); this one is a
+        // pure data flow without a follow-the-mouse ghost (v1 keeps it
+        // simple — release-over-slot is enough to be discoverable).
+        if (Game::inventory_drag_id != PetalID::kNone
+            && BitMath::at(Input::mouse_buttons_released, Input::LeftMouse)) {
+            float mx = Input::mouse_x, my = Input::mouse_y;
+            uint8_t hit = (uint8_t)-1;
+            float best = 1e9;
+            // Match the loadout backgrounds' hit-test geometry (see
+            // LoadoutPetal.cc::find_viable_target). 2*MAX_SLOT_COUNT
+            // excludes the trash slot — we only equip onto real slots.
+            for (uint8_t i = 0; i < 2 * MAX_SLOT_COUNT; ++i) {
+                Ui::UiLoadoutSlot *slot = Ui::UiLoadout::petal_backgrounds[i];
+                if (slot == nullptr) continue;
+                float dist = std::max(fabsf(mx - slot->screen_x), fabsf(my - slot->screen_y));
+                if (dist >= (slot->width + 20) * Ui::scale / 2) continue;
+                if (dist >= best) continue;
+                best = dist; hit = i;
+            }
+            if (hit != (uint8_t)-1) {
+                // dynamic_to_static: primary row (0..MAX-1) maps 1:1, secondary
+                // (MAX..2*MAX-1) collapses any gap when loadout_count < MAX.
+                uint8_t dyn = hit;
+                uint8_t pos = dyn;
+                if (dyn >= MAX_SLOT_COUNT)
+                    pos = dyn - (MAX_SLOT_COUNT - Game::loadout_count);
+                if (pos < MAX_SLOT_COUNT + Game::loadout_count) {
+                    PetalID::T new_id = Game::inventory_drag_id;
+                    PetalID::T old_id = Game::cached_loadout[pos];
+                    // Local inventory bookkeeping: consume the new petal,
+                    // refund the displaced one (matches server's logical
+                    // intent even though server doesn't track inventory).
+                    if (Game::persistent_inventory[new_id] > 0)
+                        Game::persistent_inventory[new_id]--;
+                    if (old_id != PetalID::kNone && old_id < PetalID::kNumPetals)
+                        Game::persistent_inventory[old_id]++;
+                    Game::equip_from_inventory(pos, new_id);
+                }
+            }
+            Game::inventory_drag_id = PetalID::kNone;
+        }
     } else {
         player_id = NULL_ENTITY;
         overlevel_timer = 0;
         // Reset prev tracker on death so re-equip after respawn doesn't
         // double-count surviving petals.
         Game::prev_cached_loadout.fill(PetalID::kNone);
+        // Patch 0015: drop any pending drag if we transitioned out of life.
+        Game::inventory_drag_id = PetalID::kNone;
     }
 
     //event poll
