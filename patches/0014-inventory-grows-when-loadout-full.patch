@@ -21,16 +21,23 @@ static void _pickup_drop(Simulation *sim, Entity &player, Entity &drop) {
     if (!sim->ent_alive(player.get_parent())) return;
     if (drop.immunity_ticks > 0) return;
 
+    // Try to equip into the first empty slot (legacy behavior).
     for (uint32_t i = 0; i <  player.get_loadout_count() + MAX_SLOT_COUNT; ++i) {
         if (player.get_loadout_ids(i) != PetalID::kNone) continue;
         player.set_loadout_ids(i, drop.get_drop_id());
-        drop.set_x(player.get_x());
-        drop.set_y(player.get_y());
-        BitMath::unset(drop.flags, EntityFlags::kIsDespawning);
-        sim->request_delete(drop.id);
-        //peaceful transfer, no petal tracking needed
-        return;
+        break;
     }
+    // Patch 0014: always consume the drop, even when no slot was free.
+    // Surplus pickups become inventory (counted client-side via the
+    // pending-delete-near-player heuristic in Game::tick — see
+    // Client/Game.cc tick_inventory_pickup_detection). Without this,
+    // drops piled up forever once both loadout rows filled up and the
+    // client-visible inventory stopped growing — the exact complaint.
+    // Snap to player position so the client's nearness check fires.
+    drop.set_x(player.get_x());
+    drop.set_y(player.get_y());
+    BitMath::unset(drop.flags, EntityFlags::kIsDespawning);
+    sim->request_delete(drop.id);
 }
 
