diff --git a/Client/Ui/TitleScreen/Craft.cc b/Client/Ui/TitleScreen/Craft.cc
new file mode 100644
index 0000000..36535bc
--- /dev/null
+++ b/Client/Ui/TitleScreen/Craft.cc
@@ -0,0 +1,161 @@
+// Phase 6 craft: Craft panel — lottery-style 5→1 rarity upgrade.
+//
+// Design recap (user-chosen):
+//   - For each rarity 0..5 (Common..Mythic): row showing
+//       * rarity name (color)
+//       * total petals owned at this tier
+//       * success rate %
+//       * "Craft 5" button (greyed if <5)
+//   - Output: 1 random petal of next rarity, added to persistent_inventory
+//   - Fail: 1-4 random consumed petals destroyed (refund 5-N)
+//
+// Last result is rendered as a status line at the bottom for ~5s.
+
+#include <Client/Ui/TitleScreen/TitleScreen.hh>
+
+#include <Client/Ui/Button.hh>
+#include <Client/Ui/Container.hh>
+#include <Client/Ui/StaticText.hh>
+#include <Client/Ui/DynamicText.hh>
+#include <Client/Ui/Extern.hh>
+
+#include <Client/Assets/Assets.hh>
+#include <Client/Game.hh>
+#include <Client/StaticData.hh>
+
+#include <Helpers/Math.hh>
+
+#include <format>
+#include <unordered_map>
+
+using namespace Ui;
+
+// File-scope (NOT anonymous-namespace) so the `extern` declarations inside
+// the on_click lambda below find the matching definitions with the same
+// linkage. Wrapping in `namespace {}` would give these internal linkage and
+// the lambda's extern decls would search for external — broken link.
+static std::unordered_map<Element *, uint8_t> g_craft_rarity_map;
+
+void register_craft_button(Element *btn, uint8_t rarity) {
+    g_craft_rarity_map[btn] = rarity;
+}
+uint8_t craft_rarity_for_button(Element *btn) {
+    auto it = g_craft_rarity_map.find(btn);
+    return (it == g_craft_rarity_map.end()) ? 0 : it->second;
+}
+
+namespace {
+    constexpr float SUCCESS_RATE_DISPLAY[RarityID::kNumRarities] =
+        {0.60f, 0.45f, 0.30f, 0.20f, 0.12f, 0.06f, 0.03f};
+
+    uint32_t total_at_rarity(uint8_t rarity) {
+        uint32_t total = 0;
+        for (PetalID::T id = PetalID::kBasic; id < PetalID::kNumPetals; ++id) {
+            if (PETAL_DATA[id].rarity == rarity)
+                total += Game::persistent_inventory[id];
+        }
+        return total;
+    }
+
+    Element *make_rarity_craft_row(uint8_t rarity) {
+        // Don't show row for top rarity — nothing to upgrade to.
+        bool is_top = (rarity >= RarityID::kNumRarities - 1);
+
+        Element *label = new Ui::StaticText(15, RARITY_NAMES[rarity], {
+            .fill = RARITY_COLORS[rarity],
+            .h_justify = Style::Left
+        });
+
+        Element *count_text = new Ui::DynamicText(13, [rarity]() {
+            return std::format("({}/5 available)", total_at_rarity(rarity));
+        }, { .fill = 0xffeeeeee, .h_justify = Style::Left });
+
+        Element *rate_text = new Ui::StaticText(13,
+            std::format("{:.0f}% success", SUCCESS_RATE_DISPLAY[rarity] * 100),
+            { .fill = 0xffcccccc, .h_justify = Style::Left });
+
+        if (is_top) {
+            return new Ui::HContainer({
+                label,
+                new Ui::StaticText(13, "(max tier)", { .fill = 0xff999999, .h_justify = Style::Left })
+            }, 0, 8, { .h_justify = Style::Left });
+        }
+
+        // NOTE: Button's `should_darken` is a non-capturing function pointer,
+        // so we can't bind `rarity` into it. We skip darken — feedback comes
+        // via the status text at the bottom (try_craft sets last_craft_*).
+        // `craft_rarity_for_button` and `register_craft_button` are file-scope
+        // helpers defined at the top — found via normal unqualified lookup
+        // here, no `extern` decl needed (one inside an anonymous namespace
+        // would be interpreted as anon-namespace-scoped → internal linkage,
+        // broken link).
+        Ui::Button *btn = new Ui::Button(90, 28,
+            new Ui::StaticText(13, "Craft 5", { .fill = 0xffffffff }),
+            [](Element *e, uint8_t event) {
+                if (event != Ui::kClick) return;
+                Game::try_craft(craft_rarity_for_button(e));
+            },
+            nullptr,
+            { .fill = 0xff3a8a3a, .stroke_hsv = 0.7, .line_width = 3, .round_radius = 4 }
+        );
+        register_craft_button(btn, rarity);
+
+        return new Ui::HContainer({
+            label,
+            count_text,
+            rate_text,
+            btn
+        }, 0, 10, { .h_justify = Style::Left });
+    }
+
+    Element *make_last_result_text() {
+        return new Ui::DynamicText(13, []() {
+            double age = Game::timestamp - Game::last_craft_timestamp;
+            if (age > 5.0 || Game::last_craft_timestamp < 0) return std::string("");
+            if (Game::last_craft_success) {
+                return std::format("✓ Crafted: {}", PETAL_DATA[Game::last_craft_result].name);
+            } else if (Game::last_craft_destroyed > 0) {
+                return std::format("✗ Failed. Destroyed {} of 5.", Game::last_craft_destroyed);
+            } else {
+                return std::string("Not enough petals (need 5).");
+            }
+        }, { .fill = 0xffffe066, .h_justify = Style::Left });
+    }
+}
+
+// (g_craft_rarity_map + register/lookup helpers are defined at top of file
+// so they have external linkage and the extern decls inside the lambdas
+// link correctly.)
+
+Element *Ui::make_craft_panel() {
+    std::vector<Element *> rows;
+    rows.push_back(new Ui::StaticText(22, "Craft"));
+    rows.push_back(new Ui::StaticText(12,
+        "Combine 5 same-rarity petals into 1 random next-rarity petal.",
+        { .fill = 0xffcccccc, .h_justify = Style::Left }));
+    rows.push_back(new Ui::StaticText(12,
+        "Failure destroys 1-4 of the 5 consumed.",
+        { .fill = 0xffcccccc, .h_justify = Style::Left }));
+    rows.push_back(new Ui::Element(0, 8));
+    for (uint8_t r = 0; r < RarityID::kNumRarities; ++r) {
+        rows.push_back(make_rarity_craft_row(r));
+    }
+    rows.push_back(new Ui::Element(0, 8));
+    rows.push_back(make_last_result_text());
+
+    Element *elt = new Ui::VContainer(rows, 15, 8, {
+        .fill = 0xff3a8a3a,
+        .line_width = 6,
+        .round_radius = 4,
+        .animate = [](Element *e, Renderer &ctx) {
+            ctx.translate(0, (1 - e->animation) * 2 * e->height);
+        },
+        .should_render = []() {
+            return Ui::panel_open == Panel::kCraft && Game::should_render_title_ui();
+        },
+        .h_justify = Style::Left,
+        .v_justify = Style::Bottom
+    });
+    Ui::Panel::craft = elt;
+    return elt;
+}
diff --git a/Client/Ui/TitleScreen/Inventory.cc b/Client/Ui/TitleScreen/Inventory.cc
new file mode 100644
index 0000000..8af814f
--- /dev/null
+++ b/Client/Ui/TitleScreen/Inventory.cc
@@ -0,0 +1,127 @@
+// Phase 6 craft: Inventory panel — shows lifetime pickups per petal.
+// One row per rarity, grid of petals within. Count shown under each tile
+// using format_score() so 5_000 → "5k", 5_000_000 → "5m", etc.
+
+#include <Client/Ui/TitleScreen/TitleScreen.hh>
+
+#include <Client/Ui/Container.hh>
+#include <Client/Ui/ScrollContainer.hh>
+#include <Client/Ui/StaticText.hh>
+#include <Client/Ui/DynamicText.hh>
+#include <Client/Ui/Extern.hh>
+#include <Client/Ui/InGame/Loadout.hh>
+
+#include <Client/Assets/Assets.hh>
+#include <Client/Game.hh>
+#include <Client/StaticData.hh>
+
+#include <Helpers/Math.hh>
+
+using namespace Ui;
+
+namespace {
+    // A single inventory cell: petal sprite + count badge.
+    class InventoryPetalCell final : public Element {
+    public:
+        PetalID::T id;
+        InventoryPetalCell(PetalID::T pid, float w)
+            : Element(w, w + 14, {
+                .fill = RARITY_COLORS[PETAL_DATA[pid].rarity],
+                .stroke_hsv = 0.85,
+                .line_width = 2,
+                .round_radius = w / 16,
+                .v_justify = Style::Top
+            }), id(pid) {
+            style.should_render = [pid]() {
+                return Game::persistent_inventory[pid] > 0;
+            };
+        }
+        virtual void on_render(Renderer &ctx) override {
+            Element::on_render(ctx);
+            // Draw count text FIRST. TextArgs has no `.y` — translate then
+            // draw, then translate back. Drift text to bottom of cell.
+            uint32_t n = Game::persistent_inventory[id];
+            float text_y = height / 2 - 8;
+            ctx.translate(0, text_y);
+            ctx.draw_text(format_score((float)n).c_str(), {
+                .fill = 0xffffffff,
+                .size = 10
+            });
+            ctx.translate(0, -text_y);
+            // Then scale + translate + petal — done LAST so scale doesn't
+            // bleed into text (no save/restore in this Renderer API; we
+            // rely on Element render isolation between siblings).
+            ctx.translate(0, -7);
+            ctx.scale(width / 60);
+            draw_loadout_background(ctx, id);
+        }
+        virtual void on_event(uint8_t event) override {
+            if (event != kFocusLost) {
+                rendering_tooltip = 1;
+                tooltip = Ui::UiLoadout::petal_tooltips[id];
+            } else {
+                rendering_tooltip = 0;
+            }
+        }
+    };
+
+    Element *make_rarity_row(uint8_t rarity) {
+        // Style field order: ... animate, should_render, h_justify, v_justify ...
+        // (ISO C++ requires designators in declaration order.)
+        Element *row = new Ui::HContainer({}, 0, 6, {
+            .should_render = [rarity]() {
+                for (PetalID::T id = PetalID::kBasic; id < PetalID::kNumPetals; ++id) {
+                    if (PETAL_DATA[id].rarity == rarity && Game::persistent_inventory[id] > 0)
+                        return true;
+                }
+                return false;
+            },
+            .h_justify = Style::Left
+        });
+        // rarity label (e.g. "Common")
+        row->add_child(new Ui::StaticText(13, RARITY_NAMES[rarity], {
+            .fill = RARITY_COLORS[rarity],
+            .h_justify = Style::Left
+        }));
+        for (PetalID::T id = PetalID::kBasic; id < PetalID::kNumPetals; ++id) {
+            if (PETAL_DATA[id].rarity == rarity) {
+                row->add_child(new InventoryPetalCell(id, 50));
+            }
+        }
+        return row;
+    }
+}
+
+Element *Ui::make_inventory_panel() {
+    Element *content = new Ui::VContainer({}, 0, 8, { .h_justify = Style::Left });
+    for (uint8_t r = 0; r < RarityID::kNumRarities; ++r) {
+        content->add_child(make_rarity_row(r));
+    }
+    // Empty-state hint
+    content->add_child(new Ui::DynamicText(12, []() {
+        uint32_t total = 0;
+        for (PetalID::T id = PetalID::kBasic; id < PetalID::kNumPetals; ++id)
+            total += Game::persistent_inventory[id];
+        if (total == 0) return std::string("Pick up petals from defeated mobs to fill your inventory.");
+        return std::string("Total petals owned: ") + format_score((float)total);
+    }, { .fill = 0xffcccccc, .h_justify = Style::Left }));
+
+    Element *elt = new Ui::VContainer({
+        new Ui::StaticText(22, "Inventory"),
+        new Ui::ScrollContainer(content, 350)
+    }, 15, 10, {
+        .fill = 0xff7c5cb0,  // Omega-ish purple — matches hornex rarity-bg-8
+        .line_width = 6,
+        .round_radius = 4,
+        .animate = [](Element *e, Renderer &ctx) {
+            ctx.translate(0, (1 - e->animation) * 2 * e->height);
+        },
+        .should_render = []() {
+            return Ui::panel_open == Panel::kInventory && Game::should_render_title_ui();
+        },
+        .h_justify = Style::Left,
+        .v_justify = Style::Bottom
+    });
+    Ui::Panel::inventory = elt;
+    return elt;
+}
