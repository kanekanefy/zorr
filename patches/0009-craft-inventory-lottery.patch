+
+// ─── Phase 6: Lottery Craft ─────────────────────────────────────────────────
+//
+// User decisions (recorded in docs/phase6-craft-plan.md):
+//   - per-tier success: [60, 45, 30, 20, 12, 6, 3]%  (Common→Unique)
+//   - fail destroys 1-4 random of the 5 consumed
+//   - 5 consumed are random petals of `rarity` from persistent_inventory
+//   - on success, +1 random petal of `rarity + 1`
+//   - storage: client localStorage (auto via Storage.cc STORED macro)
+//
+PetalID::T Game::try_craft(uint8_t rarity) {
+    if (rarity >= RarityID::kNumRarities - 1) {
+        // No rarity above the top tier — can't upgrade Unique.
+        Game::last_craft_result    = PetalID::kNone;
+        Game::last_craft_success   = 0;
+        Game::last_craft_destroyed = 0;
+        Game::last_craft_timestamp = Game::timestamp;
+        return PetalID::kNone;
+    }
+
+    // Collect all petals at this rarity the player has at least 1 of.
+    std::vector<PetalID::T> at_rarity;
+    uint32_t total_available = 0;
+    for (PetalID::T id = PetalID::kBasic; id < PetalID::kNumPetals; ++id) {
+        if (PETAL_DATA[id].rarity == rarity && Game::persistent_inventory[id] > 0) {
+            at_rarity.push_back(id);
+            total_available += Game::persistent_inventory[id];
+        }
+    }
+    if (total_available < 5) {
+        Game::last_craft_result    = PetalID::kNone;
+        Game::last_craft_success   = 0;
+        Game::last_craft_destroyed = 0;
+        Game::last_craft_timestamp = Game::timestamp;
+        return PetalID::kNone;
+    }
+
+    // Consume 5 from the pool. Pick weighted-random per petal-id by count
+    // (so a player with 100 Roses + 1 Stinger mostly burns Roses).
+    PetalID::T consumed[5];
+    for (uint8_t pick = 0; pick < 5; ++pick) {
+        uint32_t roll = (uint32_t)(frand() * total_available);
+        uint32_t acc = 0;
+        for (PetalID::T id : at_rarity) {
+            acc += Game::persistent_inventory[id];
+            if (roll < acc) {
+                consumed[pick] = id;
+                Game::persistent_inventory[id]--;
+                total_available--;
+                break;
+            }
+        }
+    }
+
+    // Roll success.
+    constexpr float SUCCESS_RATES[RarityID::kNumRarities] =
+        {0.60f, 0.45f, 0.30f, 0.20f, 0.12f, 0.06f, 0.03f};
+    float roll = frand();
+    if (roll < SUCCESS_RATES[rarity]) {
+        // Success: pick a random petal of next rarity that EXISTS in PETAL_DATA.
+        std::vector<PetalID::T> next_pool;
+        for (PetalID::T id = PetalID::kBasic; id < PetalID::kNumPetals; ++id) {
+            if (PETAL_DATA[id].rarity == rarity + 1) next_pool.push_back(id);
+        }
+        if (next_pool.empty()) {
+            // No higher-rarity petals defined — treat as fail, refund all 5.
+            for (uint8_t i = 0; i < 5; ++i) Game::persistent_inventory[consumed[i]]++;
+            Game::last_craft_result    = PetalID::kNone;
+            Game::last_craft_success   = 0;
+            Game::last_craft_destroyed = 0;
+            Game::last_craft_timestamp = Game::timestamp;
+            return PetalID::kNone;
+        }
+        PetalID::T result = next_pool[(uint32_t)(frand() * next_pool.size())];
+        Game::persistent_inventory[result]++;
+        Game::seen_petals[result] = 1;
+        Game::last_craft_result    = result;
+        Game::last_craft_success   = 1;
+        Game::last_craft_destroyed = 0;
+        Game::last_craft_timestamp = Game::timestamp;
+        return result;
+    } else {
+        // Fail: destroy 1-4, refund 5-N. rand() % 4 + 1 → 1..4.
+        uint8_t destroyed = 1 + (uint8_t)(frand() * 4);  // 1..4
+        if (destroyed > 4) destroyed = 4;
+        for (uint8_t i = destroyed; i < 5; ++i) {
+            Game::persistent_inventory[consumed[i]]++;
+        }
+        Game::last_craft_result    = PetalID::kNone;
+        Game::last_craft_success   = 0;
+        Game::last_craft_destroyed = destroyed;
+        Game::last_craft_timestamp = Game::timestamp;
+        return PetalID::kNone;
+    }
 }
