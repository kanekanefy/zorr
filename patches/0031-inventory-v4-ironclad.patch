+// Wipe button callback. Free function — gardn's Button takes a function
+// pointer, not std::function, so capturing lambdas don't convert.
+void wipe_inventory_cb(Element *, uint8_t event) {
+    if (event != Ui::kClick) return;
+    for (PetalID::T id = PetalID::kBasic; id < PetalID::kNumPetals; ++id) {
+        Game::persistent_inventory[id] = 0;
+    }
 }
 
