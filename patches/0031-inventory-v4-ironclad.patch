+class InventoryPetalCell final : public Element {
+public:
+    PetalID::T id;
+    InventoryPetalCell(PetalID::T pid)
+        : Element(60, 80, {
+            .fill         = RARITY_COLORS[PETAL_DATA[pid].rarity],
+            .stroke_hsv   = 0.85f,
+            .line_width   = 2,
+            .round_radius = 5,
+            .v_justify    = Style::Top,
+        }), id(pid) {}
+
+    void on_render(Renderer &ctx) override {
+        uint32_t n = Game::persistent_inventory[id];
+        bool owned = n > 0;
+
+        // --- 1) Background (with style swap for unowned/dragging) ------
+        uint32_t saved_fill = style.fill;
+        float    saved_hsv  = style.stroke_hsv;
+        float    saved_lw   = style.line_width;
+        if (!owned) {
+            style.fill       = 0xff2e2e2e;
+            style.stroke_hsv = 0.5f;
+            style.line_width = 1;
+        } else if (Game::inventory_drag_id == id) {
+            style.stroke_hsv = 1.4f;
+            style.line_width = 4;
+        }
+        Element::on_render(ctx);
+        style.fill       = saved_fill;
+        style.stroke_hsv = saved_hsv;
+        style.line_width = saved_lw;
+
+        // --- 2) Petal sprite, top half of cell -------------------------
+        // Wrap in RenderContext so the scale + translate + alpha changes
+        // auto-restore. NO manual inverse-scale.
+        {
+            RenderContext sprite_scope(&ctx);
+            ctx.translate(0, -12);
+            ctx.scale(0.62f);
+            if (!owned) ctx.set_global_alpha(0.22f);
             draw_loadout_background(ctx, id);
+        }   // ← matrix + alpha restored on scope exit
+
+        // --- 3) Petal name, bottom of cell -----------------------------
+        // Cell-local coords (no scale leak from sprite). 9pt with thick
+        // black outline for legibility on any rarity background.
+        if (owned) {
+            float ny = height / 2 - 9;
+            ctx.translate(0, ny);
+            ctx.draw_text(PETAL_DATA[id].name, {
+                .fill         = 0xffffffff,
+                .size         = 9,
+                .stroke_scale = 0.22,
+            });
+            ctx.translate(0, -ny);
+        }
+
+        // --- 4) Count badge, top-right (LAST so nothing paints over) ---
+        // Format "x44" / "x5k" / "x500m". Tucked into the top-right
+        // corner of the cell.
+        if (owned) {
+            std::string badge = std::string("x") + format_score((float)n);
+            float bx = width  / 2 - 14;
+            float by = -height / 2 + 10;
+            ctx.translate(bx, by);
+            ctx.draw_text(badge.c_str(), {
+                .fill         = 0xffffffff,
+                .size         = 12,
+                .stroke_scale = 0.25,
+            });
+            ctx.translate(-bx, -by);
+        }
+    }
+
+    void on_event(uint8_t event) override {
+        // Unowned cells are inert.
+        if (Game::persistent_inventory[id] == 0) {
+            rendering_tooltip = 0;
+            return;
+        }
+        if (event == kMouseDown && Game::alive()) {
+            Game::inventory_drag_id = id;
         }
-        virtual void on_event(uint8_t event) override {
