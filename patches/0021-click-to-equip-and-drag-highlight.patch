+
+// Patch 0021: click-to-equip. Find the first slot that's actually empty
+// (kNone) — primary row first (preferred so the petal is immediately
+// usable), then secondary row. Caller already validated id and aliveness.
+// Returns 0xff if both rows are full (caller should leave drag mode on
+// for a manual drop, or just silently no-op).
+uint8_t Game::equip_to_first_empty(PetalID::T id) {
+    if (!Game::alive()) return 0xff;
+    if (id == PetalID::kNone || id >= PetalID::kNumPetals) return 0xff;
+    if (Game::persistent_inventory[id] == 0) return 0xff;
+    // Primary: indices 0..loadout_count-1 in static-pos space.
+    for (uint8_t pos = 0; pos < Game::loadout_count; ++pos) {
+        if (Game::cached_loadout[pos] == PetalID::kNone) {
+            Game::persistent_inventory[id]--;
+            Game::equip_from_inventory(pos, id);
+            return pos;
+        }
+    }
+    // Secondary: indices MAX_SLOT_COUNT..MAX_SLOT_COUNT+loadout_count-1.
+    for (uint8_t pos = MAX_SLOT_COUNT; pos < MAX_SLOT_COUNT + Game::loadout_count; ++pos) {
+        if (Game::cached_loadout[pos] == PetalID::kNone) {
+            Game::persistent_inventory[id]--;
+            Game::equip_from_inventory(pos, id);
+            return pos;
+        }
+    }
+    return 0xff;
 }
